# --- runtime ---
NODE_ENV=development
PORT=8090

# --- database (12-factor single URL) ---
DATABASE_URL=postgres://klim:klim@localhost:5432/klim

# --- auth (JWT) ---
# expiresIn is in seconds. HS256 is enforced on sign + verify.
SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# --- CORS ---
# Comma-separated allowlist. Empty => all cross-origin requests rejected.
CORS_ALLOWED_ORIGINS=http://localhost:8080

# --- public image URLs (disk/local mode) ---
# Base prepended to stored image keys. Empty => relative paths (behind nginx).
PUBLIC_BASE_URL=

# --- tenants (optional override) ---
# JSON map of domain header => DB user id. Omit to use the built-in default.
# TENANTS={"klimstepan.com":1,"derzhanovska.com":2}

# --- object storage (S3-compatible; unset => local disk fallback) ---
# S3_ENDPOINT=http://localhost:9000        # MinIO/R2 endpoint; omit for AWS S3
# S3_REGION=auto
# S3_BUCKET=klim-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=http://localhost:9000/klim-uploads
